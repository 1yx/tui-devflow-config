{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(pnpm:*)",
      "Bash(bun:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(uv:*)",
      "Bash(openspec:*)",
      "Bash(specify:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(jq:*)",
      "Bash(tree:*)",
      "Bash(echo:*)",
      "Bash(file:*)",
      "Bash(cmux:*)",
      "WebSearch",
      "WebFetch",
      "mcp__context7__*",
      "mcp__web-search-prime__*",
      "mcp__chrome-devtools__*"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(npm:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/cmux-notify.sh PostToolUse Task"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/cmux-notify.sh Stop"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-daltonized"
}
