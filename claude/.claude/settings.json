{
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/cmux-notify.sh PostToolUse Task",
            "type": "command"
          }
        ],
        "matcher": "Task"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "~/.claude/hooks/cmux-notify.sh Stop",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(pnpm:*)",
      "Bash(bun:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(uv:*)",
      "Bash(openspec:*)",
      "Bash(specify:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(tree:*)",
      "Bash(echo:*)",
      "Bash(file:*)",
      "Bash(cmux:*)",
      "WebSearch",
      "WebFetch",
      "mcp__context7__*",
      "mcp__web-search-prime__*",
      "mcp__chrome-devtools__*"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(npm:*)"
    ]
  }
}