# cmux configuration (via Ghostty config)
# ~/.config/ghostty/config

# Default working directory
working-directory = ~

# Default shell
command = /opt/homebrew/bin/fish

# Send the macOS Option key as Alt
macos-option-as-alt = true

# Font settings
font-family = "FiraMono Nerd Font"
font-style = Regular
font-size = 12

# Theme
theme = "One Dark Two"

# Cell spacing adjustments
adjust-cell-width = 0%
adjust-cell-height = 20%

# Window settings
window-padding-x = 6
window-padding-y = 6
window-padding-balance = true
window-decoration = true

# Cursor
cursor-style = block
cursor-style-blink = false
